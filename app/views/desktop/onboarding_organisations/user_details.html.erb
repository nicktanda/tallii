<div class="flex w-full h-screen text-blue-900">
  <div class="w-1/3 p-8 space-y-4 bg-center bg-no-repeat" style="background-image: url('/app_images/Joyful Labrador Retriever.png'); background-size: 100% auto;">
    <div class="flex">
      <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60" fill="currentColor" class="h-9 w-9 text-white">
        <rect x="33" y="20" width="10" height="30" rx="1" />
        <ellipse cx="23" cy="12" rx="6" ry="5" />
        <ellipse cx="38" cy="12" rx="6" ry="5" />
        <path fill-rule="evenodd" clip-rule="evenodd" d="M19 20C18.4477 20 18 20.4477 18 21V37.5663L28 31.3176V21C28 20.4477 27.5523 20 27 20H19ZM28 37.2135L18 43.4622V49C18 49.5523 18.4477 50 19 50H27C27.5523 50 28 49.5523 28 49V37.2135Z" />
      </svg>
      <div class="text-3xl font-bold text-white">Talii</div>
    </div>
  </div>
  <div class="w-2/3 p-12">
    <div class="space-y-4">
      <div class="flex justify-center text-5xl font-bold">Welcome to Talii</div>
      <div class="flex justify-center text-sm">"Your ultimate all-in-one pet business companion!"</div>
    </div>
    <div class="mt-16 flex justify-center w-full">
      <%= form_with url: update_desktop_onboarding_organisation_user_details_path, class: "w-4/5" do |f| %>
        <div class="space-y-4 w-full">
          <div class="space-y-3 w-full">
            <%= f.text_field :name, placeholder: "Full legal name", required: true, class: "bg-white text-black w-full rounded-xl p-4" %>
            <div class="text-xs text-blue-700 px-2">Full name as it appears on identification documents</div>
          </div>
          <div class="space-y-3 w-full">
            <%= f.email_field :email, placeholder: "Business email", required: true, class: "bg-white text-black w-full rounded-xl p-4" %>
            <div class="text-xs text-blue-700 px-2">For example 'bowwow@companyname.com'</div>
          </div>
          <div class="space-y-3 w-full">
            <%= f.password_field :user_password, placeholder: "Create password", class: "bg-white text-black w-full rounded-xl p-4" %>
          </div>
          <div class="flex justify-center">
            <%= f.submit "Sign up", class: "bg-blue-800 text-white font-bold p-4 px-12 rounded-3xl flex items-center justify-center" %>
          </div>
        </div>
        <div class="space-x-2 flex justify-center items-center mt-8">
          <div class="text-sm">Already have an account?</div>
          <%= link_to "Sign in", desktop_new_session_path, class: "text-blue-800 font-bold" %>
        </div>
      <% end %>
    </div>
  </div>
</div>