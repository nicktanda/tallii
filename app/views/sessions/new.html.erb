<div class="text-center m-8 text-white">
  <div class="flex justify-center">
    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 60 60" fill="none">
      <circle cx="30" cy="30" r="29.5" stroke="white"/>
      <rect x="33" y="20" width="10" height="30" rx="1" fill="white"/>
      <ellipse cx="23" cy="12" rx="6" ry="5" fill="white"/>
      <ellipse cx="38" cy="12" rx="6" ry="5" fill="white"/>
      <path fill-rule="evenodd" clip-rule="evenodd" d="M19 20C18.4477 20 18 20.4477 18 21V37.5663L28 31.3176V21C28 20.4477 27.5523 20 27 20H19ZM28 37.2135L18 43.4622V49C18 49.5523 18.4477 50 19 50H27C27.5523 50 28 49.5523 28 49V37.2135Z" fill="white"/>
    </svg>
  </div>
  <div class="font-bold text-3xl mb-4 mt-4">Hello again!</div>
  <div class="font-light mb-16">Welcome back you've been missed!</div>
  <%= form_tag('/auth/google_oauth2', method: :post, data: { turbo: false }) do %>
    <input type="hidden" name="origin" value="<%= request.original_url %>">
    <button type="submit" class="w-full flex items-center justify-center gap-3 bg-white border border-gray-300 rounded-lg p-4">
      <svg width="20" height="20" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      <span class="font-medium text-gray-700">Continue with Google</span>
    </button>
  <% end %>
  <div class="flex items-center my-6">
    <div class="flex-grow border-t border-gray-600"></div>
    <span class="px-4 text-sm text-gray-400">or</span>
    <div class="flex-grow border-t border-gray-600"></div>
  </div>
  <%= form_with(url: create_session_path, method: :post) do |f| %>
    <div class="space-y-12 mb-8">
      <%= f.email_field :email, placeholder: "Email", required: true, class: "bg-black text-white border-x-0 border-t-0 w-full text-xl" %>
      <%= f.password_field :password, placeholder: "Password", required: true, class: "bg-black text-white border-x-0 border-t-0 w-full text-xl" %>
    </div>
    <%= f.submit 'Sign in', class: 'bg-white w-full text-black font-bold p-4 rounded-lg' %>
  <% end %>
  <div class="mt-8 flex space-x-4 justify-center">
    <div class="font-light">Not a member?</div>
    <%= link_to "Sign up", new_user_onboarding_path, class: "text-white font-bold underline" %>
  </div>
</div>
